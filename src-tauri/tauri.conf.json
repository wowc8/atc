{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-web/master/nicegram.schema.json",
  "productName": "ATC",
  "version": "0.1.0",
  "identifier": "com.atc.app",
  "build": {
    "frontendDist": "../frontend/dist"
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/atc-server"]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/wowc8/atc/releases/latest/download/latest.json"
      ]
    }
  }
}
